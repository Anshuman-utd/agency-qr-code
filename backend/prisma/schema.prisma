datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  STAFF
}

enum QrStatus {
  ACTIVE
  REVOKED
}

model Agency {
  id        String       @id @default(uuid())
  name      String
  code      String       @unique
  createdAt DateTime     @default(now())
  users     AgencyUser[]
  qrTokens  QRIssuance[]

  @@map("agencies")
}

model AgencyUser {
  id           String   @id @default(uuid())
  agencyId     String
  agency       Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(STAFF)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@map("agency_users")
}

model QRIssuance {
  id        String   @id @default(uuid())
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  token     String   @unique
  status    QrStatus @default(ACTIVE)
  issuedAt  DateTime @default(now())
  createdBy String?
  labelText String?

  @@map("qr_issuances")
}
